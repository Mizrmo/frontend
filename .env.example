# Copy to `.env` for local development (`.env` is gitignored).
# Sandbox — use while building and testing.
EXPO_PUBLIC_API_URL=https://sandbox-api.mizrmo.com/api/v1
EXPO_PUBLIC_WS_URL=https://sandbox-api.mizrmo.com

# Optional — Paystack public key if required by your Paystack setup
# EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Production — set in EAS / CI for store builds only.
# EXPO_PUBLIC_API_URL=https://api.mizrmo.com/api/v1
# EXPO_PUBLIC_WS_URL=https://api.mizrmo.com

# Paystack redirect (configure the same callback on the backend):
# mizrmo-mobile://payment-return

# Google Maps — enables Bolt-style map tiles (requires EAS/dev build rebuild):
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
