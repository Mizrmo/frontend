{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://sandbox-api.mizrmo.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "https://sandbox-api.mizrmo.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://sandbox-api.mizrmo.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "https://sandbox-api.mizrmo.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.mizrmo.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "https://api.mizrmo.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
