{
  "expo": {
    "name": "Mizrmo Mobile",
    "slug": "mizrmo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/onboarding1.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/onboarding1.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mizrmo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mizrmo.app",
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "mizrmo-mobile",
              "host": "payment-return"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-font"
    ],
    "scheme": "mizrmo-mobile"
  }
}
